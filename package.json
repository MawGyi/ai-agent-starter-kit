{
  "name": "ai-agent-starter-kit",
  "version": "1.0.0",
  "description": "A developer-friendly toolkit for building AI agents with memory, tool execution, and automation workflows.",
  "type": "module",
  "main": "dist/agent-core/index.js",
  "types": "dist/agent-core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agent-core/index.d.ts",
      "import": "./dist/agent-core/index.js"
    },
    "./tools": {
      "types": "./dist/agent-core/tools.d.ts",
      "import": "./dist/agent-core/tools.js"
    },
    "./memory": {
      "types": "./dist/agent-core/memory.d.ts",
      "import": "./dist/agent-core/memory.js"
    },
    "./vector-memory": {
      "types": "./dist/agent-core/vectorMemory.d.ts",
      "import": "./dist/agent-core/vectorMemory.js"
    },
    "./config": {
      "types": "./dist/agent-core/config.d.ts",
      "import": "./dist/agent-core/config.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "bin": {
    "ai-agent": "cli/run-agent.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch cli/run-agent.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish": "bash scripts/prepublish.sh",
    "run-agent": "tsx cli/run-agent.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "toolkit",
    "automation",
    "memory",
    "tools",
    "typescript",
    "anthropic",
    "claude",
    "vector-memory",
    "embeddings",
    "multi-agent",
    "orchestration",
    "starter-kit",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MawGyi/ai-agent-starter-kit.git"
  },
  "bugs": {
    "url": "https://github.com/MawGyi/ai-agent-starter-kit/issues"
  },
  "homepage": "https://github.com/MawGyi/ai-agent-starter-kit#readme",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
